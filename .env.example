# ============================================
# METFRAA KPI TRACKER - Environment Variables
# ============================================
# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` to git (already in .gitignore)

# --- App ---
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
BASE_URL=http://localhost:8000
TIMEZONE=Asia/Kolkata

# --- Database ---
# Local: SQLite (default). Render: paste your PostgreSQL "Internal Database URL"
DATABASE_URL=sqlite:///./app/data/metfraa.db

# --- Microsoft 365 / Azure AD (for SSO + OneDrive) ---
# From Azure Portal > App registrations
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# Must match what you register in Azure portal
MS_REDIRECT_URI=http://localhost:8000/auth/callback

# OneDrive folder under info@metfraa.com where master Excel + PDFs are stored
ONEDRIVE_FOLDER=KPI_Tracker
# The user whose OneDrive we'll use (info@metfraa.com)
ONEDRIVE_USER_EMAIL=info@metfraa.com

# --- Email (for daily reminders + missed-day alerts) ---
# Use Office 365 SMTP (works with info@metfraa.com)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=info@metfraa.com
SMTP_PASSWORD=
SMTP_FROM=info@metfraa.com
SMTP_FROM_NAME=Metfraa KPI Tracker

# --- Reminder schedule ---
DAILY_REMINDER_TIME=20:30
MISSED_DAY_ALERT_TIME=09:00
